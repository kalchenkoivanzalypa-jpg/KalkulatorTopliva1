# --- Общее ---
DATABASE_URL=sqlite+aiosqlite:///fuel_bot.db

# Ссылка на маркетинговый сайт (шапка/подвал: «Сайт компании», «Главный сайт»)
MARKETING_SITE_URL=https://nk-vsnp.ru

# Telegram-бот (обязательно для main.py / polling)
BOT_TOKEN=

# Веб: подпись сессий и OTP (смените в проде)
WEB_SECRET_KEY=change-me-long-random-string

# Веб: админка (пусто = вход в /admin отключён)
ADMIN_WEB_PASSWORD=

# SMTP — одни и те же переменные для веба (OTP, заявки) и для Telegram-бота (заявки, уведомления)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Обязательно совпадает с почтой аккаунта у многих провайдеров (Яндекс, Mail.ru)
SMTP_FROM=
# Порт 587: STARTTLS (типично). Порт 465: обычно SSL — см. SMTP_SSL ниже.
SMTP_TLS=1
# 1 = соединение через SSL с самого начала (часто порт 465: Яндекс smtp.yandex.ru)
SMTP_SSL=0
# Таймаут подключения/отправки (сек), по умолчанию 20
SMTP_TIMEOUT=20
# На VPS часто сломан IPv6 → OSError 101; по умолчанию 1 = только IPv4
SMTP_FORCE_IPV4=1

# Куда дублировать коммерческие заявки (кроме клиента)
SALES_TO_EMAIL=

# Уведомления менеджерам в Telegram (через бота)
MANAGER_TELEGRAM_IDS=

# Интервал проверки подписок на цену / аномалий (минуты)
CHECK_INTERVAL_MINUTES=60

# OTP
OTP_TTL_MINUTES=15
OTP_MAX_ATTEMPTS=5

# Опционально: импорт последнего PDF при старте бота
# SPIMEX_IMPORT_ON_STARTUP=1
